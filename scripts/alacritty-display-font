#!/usr/bin/env bash
# Launch Alacritty with a smaller font when the active display is the laptop panel.
set -euo pipefail

laptop_font_size=${ALACRITTY_LAPTOP_FONT_SIZE:-7.5}

active_laptop_panel() {
  command -v xrandr >/dev/null 2>&1 || return 1

  xrandr --query 2>/dev/null | awk '
    $2 == "connected" && $1 ~ /^(eDP|LVDS)/ {
      for (i = 3; i <= NF; i++) {
        if ($i == "primary" || $i ~ /^[0-9]+x[0-9]+\+/) {
          found = 1
        }
      }
    }
    END { exit found ? 0 : 1 }
  '
}

if active_laptop_panel; then
  exec alacritty --option "font.size=$laptop_font_size" "$@"
fi

exec alacritty "$@"
