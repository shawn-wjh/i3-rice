#!/usr/bin/env bash
# touchpad-setup — enable tap-to-click and tune scroll on whatever touchpad this
# machine has, detected by name instead of a hardcoded device id. No-op when no
# touchpad is present (e.g. desktops). Tweak the two libinput props below to taste.
set -euo pipefail

command -v xinput >/dev/null 2>&1 || exit 0

# Match any pointer device whose name contains "touchpad" (case-insensitive):
# covers Synaptics/ELAN/Goodix/Apple/etc.
ids=$(xinput list --name-only 2>/dev/null | nl -ba | awk 'tolower($0) ~ /touchpad/ {print $1}' || true)
[ -n "$ids" ] || exit 0

# Resolve names back to device ids robustly.
xinput list --short 2>/dev/null | grep -iP 'touchpad' | grep -oP 'id=\K[0-9]+' | while read -r id; do
    [ -n "$id" ] || continue
    # Each set-prop is best-effort: a prop may not exist on every driver.
    xinput set-prop "$id" "libinput Tapping Enabled" 1 2>/dev/null || true
    xinput set-prop "$id" "libinput Scrolling Pixel Distance" 35 2>/dev/null || true
done
