#!/usr/bin/env bash
# Reapply saved per-device input settings for the current X session.
set -euo pipefail

state_file="${XDG_STATE_HOME:-$HOME/.local/state}/i3/input-settings.tsv"

command -v xinput >/dev/null 2>&1 || exit 0

# When invoked outside a user session (e.g. udev/systemd), detect the X display
# from the running X socket rather than requiring DISPLAY to be pre-set.
if [[ -z ${DISPLAY:-} ]]; then
  for _x_socket in /tmp/.X11-unix/X*; do
    [[ -S $_x_socket ]] || continue
    export DISPLAY=":${_x_socket##*/X}"
    break
  done
  unset _x_socket
  [[ -n ${DISPLAY:-} ]] || exit 0
fi
if [[ -z ${XAUTHORITY:-} && -f "${HOME:-}/.Xauthority" ]]; then
  export XAUTHORITY="$HOME/.Xauthority"
fi

trim_device_name() {
  sed -E 's/^[^[:alnum:]_\/-]+//; s/[[:space:]]+id=.*$//; s/^[[:space:]]+//; s/[[:space:]]+$//'
}

list_devices() {
  xinput list --short 2>/dev/null | while IFS= read -r line; do
    [[ $line =~ id=([0-9]+) ]] || continue

    local id=${BASH_REMATCH[1]}
    local name
    name=$(printf '%s\n' "$line" | trim_device_name)

    [[ -n $name ]] || continue
    printf '%s\t%s\n' "$id" "$name"
  done
}

device_has_property() {
  local id=$1
  local property=$2

  xinput list-props "$id" 2>/dev/null |
    awk -v property="$property" '
      $0 ~ "^[[:space:]]*" property " \\([0-9]+\\):" { found = 1 }
      END { exit found ? 0 : 1 }
    '
}

apply_touchpad_defaults() {
  while IFS=$'\t' read -r id name; do
    [[ ${name,,} == *touchpad* ]] || continue
    device_has_property "$id" "libinput Natural Scrolling Enabled" || continue
    xinput set-prop "$id" "libinput Natural Scrolling Enabled" 1 2>/dev/null || true
  done < <(list_devices)
}

apply_saved_setting() {
  local saved_name=$1
  local property=$2
  local value=$3

  [[ -n $saved_name && -n $property && -n $value ]] || return 0

  while IFS=$'\t' read -r id name; do
    [[ $name == "$saved_name" ]] || continue
    device_has_property "$id" "$property" || continue
    read -ra value_args <<< "${value//,/ }"
    xinput set-prop "$id" "$property" "${value_args[@]}" 2>/dev/null || true
  done < <(list_devices)
}

apply_touchpad_defaults
[[ -s $state_file ]] || exit 0

while IFS=$'\t' read -r name property value extra; do
  [[ -z ${extra:-} ]] || continue
  apply_saved_setting "$name" "$property" "$value"
done < "$state_file"
